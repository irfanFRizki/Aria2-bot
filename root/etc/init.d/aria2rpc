#!/bin/sh /etc/rc.common
# Aria2 RPC Service for OpenWrt
# /etc/init.d/aria2rpc

START=88
STOP=10
USE_PROCD=1

NAME="aria2rpc"
PROG="/usr/bin/aria2c"
LOGFILE="/tmp/aria2rpc.log"

_info() { logger -p daemon.info -t "$NAME" "$*"; }
_err()  { logger -p daemon.err  -t "$NAME" "$*"; }

start_service() {
    if [ ! -x "$PROG" ]; then
        _err "aria2c not found at $PROG. Install: opkg install aria2"
        return 1
    fi

    _info "Starting Aria2 RPC..."

    procd_open_instance
    procd_set_param command "$PROG" \
        --enable-rpc \
        --rpc-listen-all=true \
        --rpc-allow-origin-all=true \
        --continue=true \
        --max-connection-per-server=16 \
        --file-allocation=none \
        --log="$LOGFILE" \
        --log-level=notice

    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param pidfile /var/run/aria2c.pid
    procd_close_instance

    _info "Aria2 RPC started."
}

stop_service() {
    _info "Stopping Aria2 RPC..."
    killall aria2c 2>/dev/null
}

reload_service() {
    stop
    sleep 1
    start
}

service_triggers() {
    procd_add_reload_trigger "$NAME"
}
