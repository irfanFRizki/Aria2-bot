#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

NAME="aria2bot"
PROG="/usr/bin/telegram_download_bot.py"
PIDFILE="/var/run/aria2bot.pid"
LOGFILE="/var/log/aria2bot.log"

start_service() {
    local enabled bot_token

    config_load aria2bot
    config_get enabled  settings enabled  "0"
    config_get bot_token settings bot_token ""

    if [ "$enabled" != "1" ]; then
        echo "Aria2 Bot disabled in /etc/config/aria2bot"
        return 0
    fi

    if [ -z "$bot_token" ]; then
        echo "ERROR: bot_token not set in /etc/config/aria2bot"
        return 1
    fi

    procd_open_instance
    procd_set_param command /usr/bin/python3 "$PROG"
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param file /etc/config/aria2bot
    procd_set_param pidfile "$PIDFILE"
    procd_close_instance

    echo "Aria2 Telegram Bot started."
}

stop_service() {
    echo "Stopping Aria2 Telegram Bot..."
}

reload_service() {
    stop
    sleep 1
    start
}

service_triggers() {
    procd_add_reload_trigger "aria2bot"
}
