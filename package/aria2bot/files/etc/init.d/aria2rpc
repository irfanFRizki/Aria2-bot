#!/bin/sh /etc/rc.common

START=80
STOP=20
USE_PROCD=1

NAME="aria2rpc"
PIDFILE="/var/run/aria2rpc.pid"
CONF="/etc/aria2/aria2.conf"

start_service() {
    local secret download_dir

    config_load aria2bot
    config_get secret       settings aria2_secret   ""
    config_get download_dir settings download_dir   "/tmp/downloads"

    mkdir -p "$download_dir"
    mkdir -p /etc/aria2

    [ ! -f /etc/aria2/aria2.conf ] && {
        cat > /etc/aria2/aria2.conf <<EOF
enable-rpc=true
rpc-listen-all=true
rpc-listen-port=6800
rpc-allow-origin-all=true
${secret:+rpc-secret=$secret}
dir=$download_dir
continue=true
max-concurrent-downloads=5
max-connection-per-server=10
split=10
min-split-size=1M
file-allocation=none
log=/var/log/aria2rpc.log
log-level=warn
EOF
    }

    # Update secret in conf if changed
    if [ -n "$secret" ]; then
        grep -q "rpc-secret" "$CONF" && \
            sed -i "s/^rpc-secret=.*/rpc-secret=$secret/" "$CONF" || \
            echo "rpc-secret=$secret" >> "$CONF"
    fi

    procd_open_instance
    procd_set_param command /usr/bin/aria2c --conf-path="$CONF"
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param pidfile "$PIDFILE"
    procd_close_instance

    echo "Aria2 RPC started on port 6800"
}

stop_service() {
    echo "Stopping Aria2 RPC..."
}

reload_service() {
    stop
    sleep 1
    start
}

service_triggers() {
    procd_add_reload_trigger "aria2bot"
}
